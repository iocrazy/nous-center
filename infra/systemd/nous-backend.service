[Unit]
Description=nous-center backend (FastAPI + uvicorn)
After=network-online.target postgresql.service
Wants=network-online.target
# 数据库迁到原生 pg17(2026-06-18,脱离 Docker Desktop,spec native-pg-systemd-stack)。
# postgresql.service 现在是真实存在的 unit(此前 pg 在 Docker Desktop 里、此 After 是
# 空操作)。Requires:没数据库不该起后端 —— pg 挂了 systemd 会连后端一起停,避免后端
# 在无库状态空转刷重连日志。
Requires=postgresql.service
# 稳定性加固(2026-06-16):关掉「重启限速给上限」—— 默认 5 次/10s 后 systemd 会
# 彻底放弃重启,留下永久下线(启动期 OOM/瞬时崩溃环最易踩)。单管理员推理机宁可
# 一直重试也不要静默死。RestartSec=15 拉慢重试不至于刷屏。
StartLimitIntervalSec=0

[Service]
Type=simple
User=heygo
Group=heygo
WorkingDirectory=/media/heygo/program/projects-code/repos/nous-center/backend
EnvironmentFile=/media/heygo/program/projects-code/repos/nous-center/backend/.env
# uv lives in $HOME/.local/bin; systemd doesn't read .profile, point at it
Environment=PATH=/home/linuxbrew/.linuxbrew/bin:/home/heygo/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/linuxbrew/.linuxbrew/bin/uv run uvicorn src.api.main:app --host 0.0.0.0 --port 8000
# always(2026-06-22):连「干净退出(exit 0)」也拉回 —— 核心推理后端不该因任何原因
# 静默下线(on-failure 漏掉 exit 0 / 被 SIGTERM 正常退出的情形)。配 StartLimitIntervalSec=0
# 永不放弃重试。重启/停服由 systemctl 主动发起时不受影响(那是 stop 不是 Restart 触发)。
Restart=always
RestartSec=15
# host 级 OOM 时让内核优先杀别的(桌面/临时工具),保住推理后端 —— 这是本机的核心
# 服务。注意:这只影响 host 全局 OOM 的「选谁杀」;后端自己撑爆 MemoryMax=96G 时仍由
# cgroup OOM 在本 cgroup 内处理,与此无关。
OOMScoreAdjust=-500
# Log to journald — view with `journalctl -u nous-backend -f`
StandardOutput=journal
StandardError=journal
# Hard memory cap so a vLLM bug or runaway loader can't OOM the host.
# 8G (the pre-V1 value) was below wikeeyang fp8mixed's ~18G dequant peak —
# image_generate would get SIGKILL mid-load with no useful journal output.
# Host is 125G RAM. The Ideogram-4 bf16 整装整模型(54G,from_pretrained + stream
# pin)needs ~76G peak — the old 64G cap SIGKILL'd the whole backend mid-load
# (2026-06-13 活机 e2e 坐实,见 [[project_ideogram4_integration]]). 96G fits that
# peak and still leaves ~29G headroom on the 125G host for OS + cloudflared +
# vLLM host-side + ad-hoc tools. MemoryHigh=88G applies soft pressure first.
MemoryHigh=88G
MemoryMax=96G

[Install]
WantedBy=multi-user.target
