{
  "name": "nous-center",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "wasm:build": "cd wasm/audio-engine && wasm-pack build --target web --out-dir ../../src/wasm/pkg",
    "wasm:dev": "cd wasm/audio-engine && wasm-pack build --target web --dev --out-dir ../../src/wasm/pkg",
    "predev": "npm run wasm:build",
    "prebuild": "npm run wasm:build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@xyflow/react": "^12.11.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.5"
  }
}
