# Redis (Mac)
REDIS_URL=redis://mac-ip:6379/0

# PostgreSQL (Mac)
DATABASE_URL=postgresql+asyncpg://mind:mind@mac-ip:5432/mind_center

# 模型/库路径收口(spec 2026-06-19):只给两个绝对根。各子根(LOCAL_MODELS_PATH /
# LORA_PATHS / NAS_* / *_REPO_PATH)由 configs/model_roots.yaml 的相对结构派生。
# 重格/搬盘只改这两行。
MODELS_ROOT=/media/heygo/Program/models
REPOS_ROOT=/media/heygo/Program/projects-code/github-repos

# vLLM
VLLM_BASE_URL=http://localhost:8100

# GPU
GPU_IMAGE=0
GPU_TTS=1
GPU_VIDEO=0,1

# Admin secrets — generate all three with:
#   ./infra/security/gen-admin-secrets.sh
#
# ADMIN_PASSWORD: browser login (gate /api/* + /ws/* behind a cookie session).
#   Empty disables the gate (dev mode). When set, ADMIN_SESSION_SECRET must
#   also be set or backend startup fails.
# ADMIN_SESSION_SECRET: HMAC key signing the cookie token.
# ADMIN_TOKEN: static bearer token for CLI/curl admin routes (separate from
#   browser login). Used by scripts that need to hit admin endpoints without
#   logging in via UI. Empty = CLI admin disabled.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_TOKEN=

# DB 自动备份(infra/systemd/nous-dbbackup.timer 每日 pg_dump)。设此项后启动自检 banner
# 的「DB Backup」行会显示最新备份时间;不设则 banner 显「未配置」(备份仍可由 timer 跑,
# timer 的 service 自带默认目录)。建议指向与数据盘不同的物理盘。
NOUS_DB_BACKUP_DIR=/media/heygo/Program/db-backups
# NOUS_DB_BACKUP_KEEP_DAYS=14
